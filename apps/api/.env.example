# ============================================================================
# eLIS API — Environment Variables
# Copy to .env and fill in values for local development without Docker
# ============================================================================

# --- Database ---
# When using Docker Compose, PostgreSQL is mapped to port 5433 (not 5432)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/elis_db?schema=public

# --- Authentication ---
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-me
JWT_EXPIRATION=1d

# --- Server ---
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
