# ============================================================================
# eLIS — Environment Variables Reference
# Copy this file and rename to .env.local or .env.production
# ============================================================================

# --- Database ---
# Local: postgresql://postgres:postgres123@localhost:5432/elis_db?schema=public
# Cloud: postgresql://user:pass@rds-endpoint:5432/elis_db?schema=public&sslmode=require
DATABASE_URL=

# --- Authentication ---
# Minimum 32 characters. Use a strong random string in production.
JWT_SECRET=
# Format: <number><unit> where unit is s/m/h/d (seconds/minutes/hours/days)
JWT_EXPIRATION=15m

# --- Server ---
PORT=3001
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# --- Redis ---
# Local: localhost | Docker: redis | Cloud: elasticache-endpoint
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Feature Flags ---
# Set to false to skip migrations on startup (useful for separate migration jobs)
RUN_MIGRATIONS=true
